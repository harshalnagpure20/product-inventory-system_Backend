        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const code = pm.response.code;",
                  "console.log(\"Login/Refresh status:\", code);",
                  "if (code !== 200) {",
                  "    console.warn(\"Skip token save. Status:\", code, pm.response.text());",
                  "    return;",
                  "}",
                  "let json;",
                  "try { json = pm.response.json(); } catch (e) {",
                  "    console.error(\"Invalid JSON response\", e);",
                  "    return;",
                  "}",
                  "const data = (json && json.data) ? json.data : json;",
                  "const access = data && data.access;",
                  "const refresh = data && data.refresh;",
                  "if (!access && !refresh) {",
                  "    console.warn(\"No access/refresh in response:\", JSON.stringify(json));",
                  "    return;",
                  "}",
                  "if (access) {",
                  "    pm.collectionVariables.set(\"access_token\", access);",
                  "    pm.environment.set(\"access_token\", access);",
                  "    console.log(\"access_token saved\");",
                  "}",
                  "if (refresh) {",
                  "    pm.collectionVariables.set(\"refresh_token\", refresh);",
                  "    pm.environment.set(\"refresh_token\", refresh);",
                  "    console.log(\"refresh_token saved\");",
                  "}",
                  "if (!pm.environment.name) {",
                  "    console.warn(\"No Postman environment selected. Select: Product Inventory - Local\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
